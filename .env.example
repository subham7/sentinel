# ─── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=                 # groq.com — free 14,400 req/day
ANTHROPIC_API_KEY=            # anthropic.com — analyst chat
OPENROUTER_API_KEY=           # openrouter.ai — Groq fallback

# ─── Cache ─────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=       # upstash.com — free tier
UPSTASH_REDIS_REST_TOKEN=

# ─── Flight tracking ───────────────────────────────────────────────────────────
OPENSKY_USERNAME=             # optional — adsb.fi is primary (no auth needed)
OPENSKY_PASSWORD=

# ─── Vessel tracking ───────────────────────────────────────────────────────────
AISSTREAM_API_KEY=            # aisstream.io — free, register at site

# ─── Conflict data ─────────────────────────────────────────────────────────────
ACLED_ACCESS_TOKEN=           # acleddata.com — free non-commercial

# ─── Economic ──────────────────────────────────────────────────────────────────
EIA_API_KEY=                  # eia.gov/opendata — free

# ─── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_CHANNELS_US_IRAN=
TELEGRAM_CHANNELS_ISRAEL_GAZA=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development
